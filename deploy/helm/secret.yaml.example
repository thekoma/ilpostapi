apiVersion: v1
kind: Secret
metadata:
  name: ilpost-api-credentials
type: Opaque
stringData:
  EMAIL: your-email@domain.com
  PASSWORD: your-password
  SECRET_KEY: your-secret-key-change-me
  # OIDC (Authentik)
  OIDC_ISSUER: ""
  OIDC_CLIENT_ID: ""
  OIDC_CLIENT_SECRET: ""
  OIDC_REDIRECT_URI: ""
  OIDC_ADMIN_GROUP: "admin"
  # SMTP (optional, for password reset)
  SMTP_HOST: ""
  SMTP_PORT: "587"
  SMTP_USER: ""
  SMTP_PASSWORD: ""
  SMTP_FROM: ""
